# SQLite (default) or postgresql+asyncpg://user:pass@localhost/jobagent
DATABASE_URL=sqlite:///./jobagent.db

# Optional: require X-API-Key header on API and dashboard
# API_KEY=

# Sync interval (hours)
SYNC_INTERVAL_HOURS=6

# Matching: minimum score 0-100 to show in review queue
MATCH_SCORE_THRESHOLD=25

# JSON array of Greenhouse board tokens (from boards.greenhouse.io/{token})
GREENHOUSE_BOARD_TOKENS=[]

# JSON array of Lever account slugs (from jobs.lever.co/{slug})
LEVER_ACCOUNT_SLUGS=[]

# Resume JSON for job matching + cover {{summary_line}} (default: ../resume/resume.json)
# PROFILE_JSON_PATH=
