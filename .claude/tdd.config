# ─── TDD pairing config — DATA ONLY (project-agnostic) ────────────
# team-tactics:config-schema=2
# Your project's test "layers": a layer = a slice of the codebase with its own test
# command and (optional) file globs. The orchestrator writes the active layer to
# .claude/state/layer; the hooks resolve it via .claude/hooks/lib.sh (MECHANISM,
# refreshed — do not edit). THIS FILE IS YOURS — seeded once, never clobbered.
#
#   • Single package?  keep the one "app" layer below.
#   • Monorepo?        declare several (see the full-stack example).
# Layer names must be valid shell identifiers: app, backend, frontend, e2e.

LAYERS="app chat"

# Full-suite gate (final "done" check, fallback command, SessionStart baseline).
# node --test is the fast, always-present canonical bar (the project has no `npm test`
# script; node --test auto-discovers test/*.test.mjs). chat runs its own pytest at
# edit-time + in CI; keeping the floor node-only keeps session start fast/robust.
ALL_TEST_CMD="node --test"

# ── Per-layer: TEST_CMD_<layer> (required) + optional TEST_GLOB_/SRC_GLOB_ overrides.
#   pytest: "pytest -q"   jest: "npx jest"   vitest: "npx vitest run"   go: "go test ./..."
# ── app layer: static site + contact/reporting Lambda JS ──
TEST_CMD_app="node --test"
TEST_GLOB_app='(\.test\.|\.spec\.|(^|/)tests?/)'
SRC_GLOB_app='(^|/)(js|scripts|aws)/'

# ── chat layer: FastAPI Gemini chat/voice backend (Python) ──
# Runs from repo root; the hook does `cd $ROOT && eval "$TEST_CMD"`. Mirrors CI
# (working-directory: docker/chat, PYTHONPATH=.). Cold start imports langchain.
TEST_CMD_chat="cd docker/chat && PYTHONPATH=. python3 -m pytest tests -q"
TEST_GLOB_chat='(^|/)docker/chat/tests/.*\.py$|(^|/)docker/chat/conftest\.py$'
SRC_GLOB_chat='(^|/)docker/chat/app/'

# ── Full-stack example (set LAYERS above, then define each layer) ──
# LAYERS="backend frontend e2e"
# ALL_TEST_CMD="pnpm verify"
# TEST_CMD_backend="pnpm --filter @app/backend test"
# TEST_GLOB_backend='(^|/)backend/.*(\.test\.ts|\.spec\.ts)$'
# SRC_GLOB_backend='(^|/)backend/src/.*\.ts$'
# TEST_CMD_frontend="pnpm --filter @app/frontend test"
# TEST_GLOB_frontend='(^|/)frontend/.*(\.test\.tsx?|\.spec\.tsx?)$'
# SRC_GLOB_frontend='(^|/)frontend/src/.*\.(ts|tsx)$'
# TEST_CMD_e2e="pnpm --filter @app/e2e test"
# TEST_GLOB_e2e='(^|/)e2e/.*\.spec\.ts$'

# Lines of failing output to surface back into the conversation.
TAIL_LINES=40

# Knobs (uncomment to change): SESSION_BASELINE_CHECK=0 disables the start check;
# BASELINE_CMD="<faster subset>" for big suites; TELEMETRY=0 disables cycle telemetry.
# TEAM_ACCOUNTABILITY=0 silences the solo-drift backstop (Stop hook advisory NOTE).
# SOLO_DRIFT_CYCLES=3 sets the signal-tic threshold for "substantial solo work".
# PROMPT_DIRECTIVE=1 enables the every-prompt full-framework directive (UserPromptSubmit hook; OFF by default; auto-silent in CI even when enabled). The reactive solo-drift backstop is the default accountability.

# ── Sensitive-surface gate (ADR 0017, v0.60). guard-edit-scope BLOCKS edits to paths matching
#   SECURITY_GLOB in EVERY phase (incl. `off`) unless SECURITY_REVIEW=1 is set for that edit (after a
#   deliberate architect/security review). Empty/unset = no-op. Grounded in THIS repo's auth / secret /
#   CORS / token / outbound-email / IAM surfaces: admin + sender + ingress Lambdas, shared email/query
#   code, SAM templates, the chat app entry + live-voice token modules, and the secrets scripts.
#   Routine reporting logic (daily-report, session-timeline, *-shared) and frontend js/ stay unblocked.
#   Trim or widen this one line freely — it is plain ERE matched by `grep -E`.
# ── Sensitive-surface gate RE-ARMED 2026-06-17 after the pre-prod hardening gated batch landed. ──
SECURITY_GLOB='(^|/)aws/src/(contact-(admin|sender|sender-core|ingress|ingress-core)|events-ingress(-core)?|common/(resend|report-queries|report-queries-core))\.js|(^|/)aws/(template|chat-template)\.yaml|(^|/)docker/chat/app/(main|lambda_handler|live_env|live_gemini)\.py|(^|/)scripts/(push_local_secrets_to_sm|seed_local_configs)\.py'

# ── Per-role model tiering (ADR 0010). The ORCHESTRATOR reads these when it spawns each role's
#   subagent — a CONVENTION, not a hook (the gate never sees the spawn). Absent → the orchestrator's
#   default model (today's behavior; zero change). `tics roster` shows the resolved roster. Principle:
#   spend capability where JUDGMENT lives; economize where the task is CONSTRAINED — the failing test is
#   the spec, so a cheaper IMPLEMENTER is the safe tier-down, NOT the test-writer. Values are model ids.
#   MODEL_TEST_WRITER="<your capable model>"     # test DESIGN: what to assert + the negatives  (capable)
#   MODEL_ARCHITECT="<your capable model>"       # contracts / ADRs                              (capable)
#   MODEL_TDD_CRITIC="<your capable model>"      # the over-build / drift audit                  (capable)
#   MODEL_PRODUCT_OWNER="<your capable model>"   # acceptance + prioritization                   (capable)
#   MODEL_IMPLEMENTER="<your faster model>"      # minimal green, constrained by the test        (fast)
#   MODEL_QA_VERIFIER="<your faster model>"      # drive the running app + report defects         (fast)
#   MODEL_PROJECT_MANAGER="<your faster model>"  # release mechanics                              (fast)
#   MODEL_DEV_OPS="<your faster model>"          # git / deploy mechanics                         (fast)

# ── Parallel work = one git worktree per track, sharing ONE tic bus (ADR 0015) ──
# Git isolates; the bus observes. Each track is its own worktree with its own tree,
# index, and .claude/state — git provides write-isolation, so there is no in-tree
# session protocol. Point every worktree at ONE concurrency-safe spool bus so the
# conductor/board/claims correlate across them (loadTicsAll merges the worktrees);
# without this each worktree keeps its own state and the bus fragments. Uncomment BOTH:
# TIC_STORE=spool
# TICS_DIR="$(cd "$ROOT" && cd "$(git rev-parse --git-common-dir)" && pwd)/tics-bus"

# Honest green: after a passing suite, run-suite also runs a type-check so a tests-green /
# tsc-red cycle (e.g. noUncheckedIndexedAccess) can't pass the signal. This is AUTO-ON: if you
# don't set TYPECHECK_CMD, run-suite auto-detects one — your package.json "typecheck" script if
# present, else `tsc --noEmit` when a tsconfig.json exists (non-TS projects: no-op).
#   TYPECHECK_CMD="npx tsc --noEmit"   # override the auto-detected command
#   TYPECHECK_AUTO=0                   # opt out of auto-detection entirely

# ── Fleet liveness tiers shown by `tics board` + the `tics cycle` fleet-health line (ADR 0008).
#   Default-safe when absent; uncomment to tune. A claim is freed only by release-on-section-done
#   (ADR 0015); these tiers are display-only and never expire a claim.
#   LIVENESS_IDLE_SEC=300    # no tic within this window → 'idle'  (default 5 min).
#   LIVENESS_STALE_SEC=900   # no tic within this window → 'stale'; a stale scope-holder is flagged
#                            #   STUCK in `tics board` (default 15 min).

# ── Honest gate: trust greens the referee actually produced (ADR 0009). `tics report` always splits
#   greens into hook-signed (from the run-suite hook) vs self-reported (an agent hand-emitted it, e.g. a
#   non-Claude-Code tool); `tics gate` SURFACES a warning when a release has only self-reported greens.
#   ATTEST_ENFORCE=1   # turn the warning into a hard BLOCK: `tics gate` fails when greens exist but
#                      #   none is hook-signed. Off by default (flag-only). Never blocks when a hook-signed
#                      #   green exists or there are zero greens (no false alarms on old/empty/solo buses).

# ── Evidence gate: trust greens that were TEST-FIRST (ADR 0011). A green on a scope is honored only if a
#   hook-signed RED preceded it on that scope (red→green proven from the signal trail). `tics gate` SURFACES
#   a warning for a hook-signed green with no preceding red. ATTEST_ENFORCE = "was it refereed?";
#   EVIDENCE_ENFORCE = "was it test-first?" — two independent dials (set neither, either, or both).
#   EVIDENCE_ENFORCE=1 # turn the warning into a hard BLOCK: `tics gate` fails when a scoped hook-signed
#                      #   green has no red-before-green. Off by default (flag-only). Never blocks when the
#                      #   green is evidenced, there are no greens, or only no-scope/`*` greens (no false alarms).

# ── Per-tool witness: a faithful activity record (ADR 0013). When ON, a PostToolUse hook emits a
#   `note` tic (from=witness, "used <Tool>") per tool call — so `tics report` can tally tool usage
#   (the enabler for an onboarding-overhead metric). Default OFF (no bus growth). `tics log` HIDES
#   witness notes by default (the thread stays readable); `tics log --witness` reveals them. A RECORD,
#   never a gate (no hook blocks on tool usage). NOTE: ON witnesses every tool call → the bus grows.
#   TOOL_WITNESS=1     # turn the per-tool witness ON (opt-in; absent/0 = off, a fast no-op).
