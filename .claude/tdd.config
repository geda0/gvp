# ─── teamentic config — DATA ONLY (gvp-portfolio) ───
# teamentic:config-schema=2
# gvp: static portfolio + Gemini Live voice chat + AWS contact pipeline.
#
# Two independently-tested layers:
#   app  — node:test over the static site + AWS contact Lambda JS (js/ scripts/ aws/).
#   chat — pytest over the Gemini chat/voice FastAPI backend (docker/chat/app/).
# Split is justified: the chat backend is a separate Python tree with its own 70-test
# pytest suite, already CI-gated by .github/workflows/docker-compose-chat-ci.yml.
#
# Green baseline recorded 2026-06-03:  app 10/10 · chat 70/70.

LAYERS="app chat"

# SessionStart floor + per-layer fallback. Node is the fast, always-present canonical
# bar ("never regress node --test"). The chat layer runs its own pytest suite at
# edit-time (PostToolUse) and in CI; keeping the floor node-only keeps session start
# fast and robust to a missing local Python env.
ALL_TEST_CMD="node --test"

# ── app layer: static site + contact Lambda JS ──
TEST_CMD_app="node --test"
TEST_GLOB_app='(\.test\.|\.spec\.|(^|/)tests?/)'
SRC_GLOB_app='(^|/)(js|scripts|aws)/'

# ── chat layer: FastAPI Gemini chat/voice backend (Python) ──
# Runs from repo root; the hook does `cd $ROOT && eval "$TEST_CMD"`. Mirrors CI
# (working-directory: docker/chat, PYTHONPATH=.). Cold start imports langchain
# (~100s once per session); warm runs ~5s.
TEST_CMD_chat="cd docker/chat && PYTHONPATH=. python3 -m pytest tests -q"
TEST_GLOB_chat='(^|/)docker/chat/tests/.*\.py$|(^|/)docker/chat/conftest\.py$'
SRC_GLOB_chat='(^|/)docker/chat/app/'

TAIL_LINES=40
