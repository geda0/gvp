# Canonical template for deploy-time environment variables.
# Copy to .secrets/deploy.env (gitignored), chmod 600, and fill in real values.
# Sourced by scripts/orchestrate-deploy.sh; scripts/integrate-and-deploy.sh also
# loads .secrets/deploy.env when RESEND_API_KEY is not already set (e.g. local shell).
#
# GitHub Actions: create repository secrets with the SAME names (no "export" prefix).
# Optional repo variables: AWS_REGION, SAM_STACK_NAME, SAM_STACK_NAME_STAGE (see README).
#
# Deploy script: bash scripts/integrate-and-deploy.sh [prod|stage]
#   prod  — this stack name (default below)
#   stage — SAM_STACK_NAME_STAGE (default page-staging) for a separate AWS environment

export AWS_REGION=us-east-2
export SAM_STACK_NAME=page
# export SAM_STACK_NAME_STAGE=page-staging

# Required for SAM parameter overrides (see aws/template.yaml Parameters)
export RESEND_API_KEY=replace-with-resend-key
export CONTACT_TO_EMAIL=contact@example.com
export CONTACT_FROM_EMAIL='Site <noreply@example.com>'
export ALARM_EMAIL=ops@example.com
export ADMIN_API_KEY=replace-with-long-random-secret

# Optional SAM parameter (defaults to CONTACT_TO_EMAIL in stack if omitted)
# export CONTACT_REPORT_EMAIL=ops@example.com

# Optional: after deploy, patch gvp:contact-api-url in index.html + admin/index.html (default 1)
# export SYNC_API_URLS=1
