# Copy to .secrets/deploy.env and fill in (chmod 600).
# Sourced by scripts/orchestrate-deploy.sh before SAM deploy.

export AWS_REGION=us-east-2
export SAM_STACK_NAME=page

export RESEND_API_KEY=replace-with-resend-key
export CONTACT_TO_EMAIL=contact@example.com
export CONTACT_FROM_EMAIL='Site <noreply@example.com>'
export ALARM_EMAIL=ops@example.com
export ADMIN_API_KEY=replace-with-long-random-secret

# optional
# export CONTACT_REPORT_EMAIL=ops@example.com

# BigQuery traffic (optional; TRAFFIC_SERVICE_ACCOUNT_SECRET_ARN often set by manifest exportAs)
# TRAFFIC_GCP_PROJECT_ID can be seeded from config.manifest.json (default: homepage-496107)
# export TRAFFIC_GCP_PROJECT_ID=homepage-496107
# export TRAFFIC_BIGQUERY_DATASET=analytics_123456789
# export TRAFFIC_SERVICE_ACCOUNT_SECRET_ARN=arn:aws:secretsmanager:...

# optional: skip pushing GCP JSON from integrate script if ARN already set above
# unset GCP_SERVICE_ACCOUNT_JSON

# optional HTML meta sync after deploy
# export SYNC_API_URLS=1
# export TRAFFIC_REPORT_EMBED_URL=
