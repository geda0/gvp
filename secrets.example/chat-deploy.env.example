# Optional chat / ECR / ECS vars (copy to .secrets/chat-deploy.env, chmod 600).
# Sourced by scripts/integrate-and-deploy.sh when present, after deploy.env.
# Omitted vars skip chat image push and ECS roll (set CHAT_ALWAYS_BUILD=1 to docker build only).

export AWS_REGION=us-east-2

# Staging chat URL for HTML meta (integrate-and-deploy.sh stage; default in script if unset)
# export CHAT_STAGE_CHAT_API_URL=https://chat.marwanelgendy.link/api/chat

# Prod chat URL for HTML meta sync (integrate-and-deploy.sh prod only)
# export CHAT_PROD_CHAT_API_URL=https://your-prod-chat-host.example/api/chat

# ECR repository URI (no tag), e.g. 123456789012.dkr.ecr.us-east-2.amazonaws.com/gvp-chat
# export CHAT_ECR_REPOSITORY_URI=

# ECS: stage uses *_STAGE or legacy CHAT_ECS_CLUSTER + CHAT_ECS_SERVICE
# export CHAT_ECS_CLUSTER_STAGE=my-staging-cluster
# export CHAT_ECS_SERVICE_STAGE=gvp-chat-staging
# export CHAT_ECS_CLUSTER_PROD=my-prod-cluster
# export CHAT_ECS_SERVICE_PROD=gvp-chat-prod

# Task definition / compose: allow browser calls from the static site origin (comma-separated).
# Example: https://marwanelgendy.link,https://www.marwanelgendy.link
# export CHAT_CORS_ORIGINS=
