# Optional chat / ECR / ECS / Lambda SAM (copy to .secrets/chat-deploy.env, chmod 600).
# Sourced by scripts/integrate-and-deploy.sh when present, after deploy.env.
# Omitted vars skip the matching step (see README).

export AWS_REGION=us-east-2

# --- Lambda chat (Gemini) via aws/chat-template.yaml ---
# When set, integrate-and-deploy runs sam build/deploy for this stack after the contact stack.
# Prefer per-environment stack names: CHAT_SAM_STACK_NAME_STAGE (stage deploy) / CHAT_SAM_STACK_NAME_PROD (prod), or legacy CHAT_SAM_STACK_NAME for both.
# Requires GEMINI_API_KEY (Google AI Studio). Pass GeminiApiKey at deploy (template has no default key).
# export CHAT_SAM_STACK_NAME_STAGE=gvp-chat-stage
# export CHAT_SAM_STACK_NAME_PROD=gvp-chat-prod
# export GEMINI_API_KEY=your-key
# export GEMINI_MODEL=gemini-3.1-flash-lite
# export GEMINI_FALLBACK_MODEL=gemma-4-26b-a4b-it
# export GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Optional: different Live model for voice only (SAM ChatVoiceModel → CHAT_VOICE_MODEL; empty inherits GEMINI_LIVE_MODEL).
# export CHAT_VOICE_MODEL=
# Same intent as CHAT_VOICE_MODEL when you prefer a GEMINI_* name in env-only deploys (ECS); lower precedence than CHAT_VOICE_MODEL.
# export GEMINI_VOICE_MODEL=
# Optional: path to a second system-prompt.md (same prompt-version header rules) used only for Live voice instructions.
# export CHAT_VOICE_SYSTEM_PROMPT_PATH=/app/docker/chat/prompts/voice-system-prompt.md
# Optional: short extra voice-only instructions appended after the grounded XML block (keep small; capped in code).
# export CHAT_VOICE_SYSTEM_APPEND=Prefer short sentences; do not read URLs aloud character by character.
# Latency tuning (optional): larger prompts + tool calls often need >15s; defaults in code are 28s / 896 max output tokens / 14k knowledge XML cap.
# export GEMINI_TIMEOUT_SECONDS=28
# export GEMINI_MAX_OUTPUT_TOKENS=896
# export CHAT_KNOWLEDGE_PACK_MAX_CHARS=14000
# Comma-separated origins for FastAPI CHAT_CORS_ORIGINS only (HTTP API has no CorsConfiguration in chat-template.yaml; CORS is enforced in app).
# Include every browser origin that loads the chat UI (apex, www, chat subdomain). Two-label https apex entries also get https://chat.<apex> automatically in app code.
# export CHAT_CORS_ORIGINS=https://chat.marwanelgendy.link,https://marwanelgendy.link,https://www.marwanelgendy.link

# --- Gemini Live voice (browser mic) ---
# Browser voice requires WebSocket relay: POST /api/live/session must return liveVoiceTransport=relay and wss://…/api/live/relay/… on THIS host.
# API Gateway HTTP API + Lambda cannot upgrade browser WebSockets; aws/chat-template.yaml sets CHAT_LIVE_RELAY=0 there (text chat only for voice from browser).
# ECS/ALB (or any long-lived WSS host): docker/chat/Dockerfile defaults CHAT_LIVE_RELAY=1. Override only if you know you need direct_google (not recommended for voice).
# export CHAT_LIVE_RELAY=1

# Staging: override HTML meta chat URL (optional if chat SAM deploy runs — stack output ChatPostApiUrl is used when this is unset).
# For voice: point at the same WSS-capable host as uvicorn (ALB/ECS), not only the Lambda execute-api URL.
# export CHAT_STAGE_CHAT_API_URL=https://your-staging-chat-alb.example.com/api/chat

# Prod chat URL for HTML meta sync (integrate-and-deploy.sh prod only).
# For voice: set to your ECS/ALB chat base …/api/chat so gvp:chat-api-url and WebSocket relay share one origin.
# export CHAT_PROD_CHAT_API_URL=https://your-prod-chat-host.example/api/chat
#
# HTML meta auto-patch: when CHAT_PROD_CHAT_API_URL / CHAT_STAGE_CHAT_API_URL are unset, integrate-and-deploy
# derives …/api/chat from the ECS service’s first ALB/NLB (describe-services → target group → load balancer DNS).
# Opt out: export CHAT_ECS_AUTO_SYNC_CHAT_URL=0
# Optional: export CHAT_ECS_CHAT_API_SCHEME=http   # default https
# Optional: export CHAT_ECS_CHAT_API_PATH=/api/chat # default /api/chat

# ECR repository URI (no tag), e.g. 123456789012.dkr.ecr.us-east-2.amazonaws.com/gvp-chat
# export CHAT_ECR_REPOSITORY_URI=

# ECS: stage uses *_STAGE or legacy CHAT_ECS_CLUSTER + CHAT_ECS_SERVICE
# Container env CHAT_TRANSCRIPTS_TABLE must be the contact stack output ChatTranscriptsTableName (admin reads the same table).
# Lambda chat: integrate-and-deploy passes ChatTranscriptsTableName into the chat SAM stack automatically.
# Optional: chat Lambda error alarm SNS email (defaults to ALARM_EMAIL from deploy.env when unset):
# export CHAT_ERROR_ALARM_EMAIL=you@example.com
# export CHAT_ECS_CLUSTER_STAGE=my-staging-cluster
# export CHAT_ECS_SERVICE_STAGE=gvp-chat-staging
# export CHAT_ECS_CLUSTER_PROD=my-prod-cluster
# export CHAT_ECS_SERVICE_PROD=gvp-chat-prod
