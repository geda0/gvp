# Contact email delivery (required for deploy script / SAM)
RESEND_API_KEY=replace-with-your-resend-api-key
CONTACT_TO_EMAIL=contact@example.com
CONTACT_FROM_EMAIL=Site <noreply@example.com>
ALARM_EMAIL=ops@example.com

# Optional failure summary recipient (defaults to CONTACT_TO_EMAIL if omitted)
# CONTACT_REPORT_EMAIL=ops@example.com

# Required for private /admin dashboard API access
ADMIN_API_KEY=replace-with-a-long-random-secret

# Optional: scripts/integrate-and-deploy.sh + GitHub Actions traffic integration
# TRAFFIC_GCP_PROJECT_ID=
# TRAFFIC_BIGQUERY_DATASET=
# TRAFFIC_SERVICE_ACCOUNT_SECRET_ARN=
# TRAFFIC_GA4_PROPERTY_ID=   # optional fallback source when BigQuery is stale/unavailable
# GCP_SERVICE_ACCOUNT_JSON=   # or TRAFFIC_SECRET_NAME=gvp/ga4-bq-reader to auto-create in Secrets Manager
# SAM_STACK_NAME=page
# AWS_REGION=us-east-2
# SYNC_API_URLS=1
# TRAFFIC_REPORT_EMBED_URL=   # optional Looker Studio embed URL (written to admin meta only)
