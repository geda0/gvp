@@ -0,0 +1,28 @@
+#!/usr/bin/env bash
+# run-suite.sh — PostToolUse hook (matcher: Edit|Write|MultiEdit)
+#
+# The arbiter. After any edit, run the full suite, record green/red to a state
+# file, and surface a concise result (plus failing tail) back into the
+# conversation so BOTH the orchestrator and the active subagent see ground
+# truth. The agents coordinate THROUGH this result, not through chat.
+
+set -uo pipefail
+HERE="$(cd "$(dirname "$0")" && pwd)"
+ROOT="$(cd "$HERE/../.." && pwd)"
+source "$ROOT/.claude/tdd.config"
+
+mkdir -p "$ROOT/.claude/state"
+STATUS_FILE="$ROOT/.claude/state/suite-status"
+
+OUT="$(cd "$ROOT" && eval "$TEST_CMD" 2>&1)"
+CODE=$?
+
+if [ $CODE -eq 0 ]; then
+  echo "green" > "$STATUS_FILE"
+  echo "✅ SUITE GREEN — all tests pass."
+else
+  echo "red" > "$STATUS_FILE"
+  echo "❌ SUITE RED (exit $CODE). Last $TAIL_LINES lines:"
+  printf '%s\n' "$OUT" | tail -n "$TAIL_LINES"
+fi
+exit 0
