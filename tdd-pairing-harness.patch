+# ─── TDD pairing kit configuration (tailored for gvp) ─────────────
+# Sourced by every hook script.
+
+# This feature is frontend/data, so the suite is the node:test runner.
+# (The chat backend's pytest suite under docker/chat is unrelated here.)
+TEST_CMD="node --test"
+
+# TEST files for this repo: node:test specs under test/.
+TEST_GLOB='(^|/)test/|\.test\.mjs$'
+
+# Fixtures the test-writer may also touch during the red phase.
+FIXTURE_GLOB='(^|/)(test/fixtures|test/__fixtures__)/'
+
+# Lines of failing output to surface back into the conversation.
+TAIL_LINES=40
diff --git a/.claude/tdd/PROTOCOL.md b/.claude/tdd/PROTOCOL.md
