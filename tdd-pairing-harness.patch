@@ -0,0 +1,26 @@
+#!/usr/bin/env bash
+# require-green-to-stop.sh — Stop AND SubagentStop hook
+#
+# Refuses to let an agent end its turn with a failing suite WHEN the suite is
+# supposed to be green. During the 'red' phase a failing suite is correct
+# (we just wrote a failing test), so we allow stopping there.
+#
+# Exit 2 on a Stop/SubagentStop hook forces the agent to keep working and
+# feeds the stderr reason back in. (Confirm this semantics for your version.)
+
+set -uo pipefail
+HERE="$(cd "$(dirname "$0")" && pwd)"
+ROOT="$(cd "$HERE/../.." && pwd)"
+
+PHASE="$(cat "$ROOT/.claude/state/phase" 2>/dev/null || echo unknown)"
+STATUS="$(cat "$ROOT/.claude/state/suite-status" 2>/dev/null || echo unknown)"
+
+case "$PHASE" in
+  green|refactor)
+    if [ "$STATUS" = "red" ]; then
+      echo "Cannot stop: phase=$PHASE but the suite is RED. In green/refactor the suite must pass. Keep going until tests are green (or revert the refactor). Do NOT edit tests to force green." >&2
+      exit 2
+    fi
+    ;;
+esac
+exit 0
